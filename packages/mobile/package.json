{
  "name": "@nicotind/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Capacitor shell (Android + iOS) wrapping the @nicotind/web build",
  "scripts": {
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "cap:add": "cap add android",
    "cap:sync:ios": "cap sync ios",
    "cap:open:ios": "cap open ios",
    "cap:add:ios": "cap add ios",
    "android:assemble": "cd android && ./gradlew assembleRelease",
    "icons:source": "bun run scripts/generate-native-icons.ts",
    "icons:generate": "bunx @capacitor/assets@3 generate"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/network": "^6.0.3",
    "@capacitor/preferences": "^6.0.3",
    "@jofr/capacitor-media-session": "^4.0.0",
    "@nicotind/capacitor-now-playing": "workspace:*"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0",
    "sharp": "^0.35.3"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/service-manager" },
    { "path": "packages/slskd-client" },
    { "path": "packages/navidrome-client" },
    { "path": "packages/api" },
    { "path": "packages/cli" },
    { "path": "src" }
  ]
}

{
  "name": "nicotind",
  "version": "0.1.113",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "dev": "bun run ./scripts/dev.ts",
    "build": "bun run ./scripts/build.ts",
    "lint": "eslint --no-warn-ignored packages/*/src/**/*.ts src/**/*.ts",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'src/**/*.ts'",
    "typecheck": "tsc --build",
    "download-deps": "bun run ./scripts/download-deps.ts",
    "test": "bun test packages src --path-ignore-patterns='**/dist/**' --path-ignore-patterns='**/.worktrees/**' --path-ignore-patterns='**/web/src/**' --path-ignore-patterns='**/e2e/**'",
    "test:tdd": "bun --watch test packages src --bail 1 --path-ignore-patterns='**/dist/**' --path-ignore-patterns='**/.worktrees/**' --path-ignore-patterns='**/web/src/**' --path-ignore-patterns='**/e2e/**'",
    "test:coverage": "bun test packages src --coverage --coverage-reporter=text --coverage-reporter=lcov --path-ignore-patterns='**/dist/**' --path-ignore-patterns='**/.worktrees/**' --path-ignore-patterns='**/web/src/**' --path-ignore-patterns='**/e2e/**'",
    "e2e": "bun run --filter @nicotind/e2e test",
    "test:api": "bun test packages/api/src --path-ignore-patterns='**/dist/**'",
    "test:web": "bun run --cwd packages/web ng test",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "prepare": "husky"
  },
  "dependencies": {
    "@nicotind/api": "workspace:*",
    "@nicotind/core": "workspace:*",
    "@nicotind/lidarr-client": "workspace:*",
    "@nicotind/service-manager": "workspace:*",
    "@nicotind/slskd-client": "workspace:*",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/bun": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}

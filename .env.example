# NicotinD Configuration
NICOTIND_PORT=8484
NICOTIND_DATA_DIR=~/.nicotind
NICOTIND_MUSIC_DIR=~/Music
NICOTIND_METADATA_FIX_ENABLED=true
NICOTIND_METADATA_FIX_MIN_SCORE=85

# Auto-acquisition loop: poll Lidarr's wanted/missing list and auto-hunt+download
# monitored albums Lidarr lacks (same engine as the interactive hunt). Off by
# default — it initiates downloads unattended. See docs/auto-acquisition-plan.md.
NICOTIND_AUTO_ACQUIRE_ENABLED=false

# Download recovery: auto-retry failed/truncated slskd transfers (slskd resumes
# the partial file) and fall back to another peer for tracks that keep failing.
NICOTIND_AUTO_RETRY_ENABLED=true
NICOTIND_RETRY_MAX_ATTEMPTS=3
NICOTIND_RETRY_INTERVAL_MS=15000
NICOTIND_RETRY_COOLDOWN_MS=60000
# Cross-peer album fallback: max recovery waves (recorded alternates + fresh
# per-track searches) before a hunt job is marked exhausted.
NICOTIND_FALLBACK_MAX_ATTEMPTS=5
# Drop an incoming MP3 when a FLAC of the same track is already in the album
# folder (avoids mixed MP3+FLAC duplicate albums). Off by default.
NICOTIND_PREFER_FLAC_SKIP_MP3=false
# Standardize lossless downloads (FLAC/WAV/…) on Opus before they enter the
# library (smaller files + uniform browser-native codec). Requires ffmpeg.
# Default-on at 192 kbps; already-lossy files are left untouched. Set ENABLED=false
# to keep originals.
NICOTIND_TRANSCODE_LOSSLESS_ENABLED=true
NICOTIND_TRANSCODE_LOSSLESS_BITRATE=192
# Absolute path to ffmpeg binary (e.g. for packaged builds). Defaults to PATH lookup.
# NICOTIND_FFMPEG_PATH=/opt/app/resources/ffmpeg

# Soulseek credentials
SOULSEEK_USERNAME=
SOULSEEK_PASSWORD=

# Mode: "embedded" (manage sub-services) or "external" (connect to existing)
NICOTIND_MODE=embedded

# External service URLs (only needed if NICOTIND_MODE=external)
NICOTIND_SLSKD_URL=http://localhost:5030

# Spotify metadata fallback lane (optional). Used to find an album in the Spotify
# catalog when Soulseek comes up empty, then download it via the spotDL plugin.
# Register an app at https://developer.spotify.com/dashboard for these. Primary
# path is Settings → Plugins; these env vars just seed the credentials headlessly.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Audio-analysis sidecar (packages/analysis) — fills mood/valence/danceability/
# acousticness/instrumentalness + cached embeddings. Optional; leave unset to
# run without it. Docker compose sets http://analysis:8000.
NICOTIND_ANALYSIS_URL=

# Process-before-landing gate — set to 1 to DISABLE it (downloads then appear in
# the library immediately, without waiting for their required processing steps).
# Off by default (gate active). Mainly an ops/test escape hatch.
# NICOTIND_DISABLE_LANDING_GATE=

# Error tracking (Sentry) — opt-in. Leave DSN empty to disable entirely.
NICOTIND_SENTRY_DSN=
NICOTIND_SENTRY_TRACES_SAMPLE_RATE=0.1
